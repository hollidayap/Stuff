<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>today</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

  :root{
    --peri:#4E4E93;
    --peri-soft:#E7E7F5;
    --peri-line:#B6B6DA;
    --oxblood:#5E1822;
    --oxblood-soft:#EEDADB;
    --cream:#FBFAF6;
    --ink:#25252b;
    --muted:#6b6b76;
    --olive:#565B33;
    --cherry:#7C2230;
    --paper:#ffffff;
  }

  *{box-sizing:border-box;margin:0;padding:0;}
  html{-webkit-text-size-adjust:100%;}
  body{
    font-family:'Inter',sans-serif;
    background:var(--cream);
    color:var(--ink);
    line-height:1.5;
    padding:0 0 80px;
    -webkit-font-smoothing:antialiased;
  }
  ::selection{background:var(--oxblood-soft);}

  .wrap{max-width:680px;margin:0 auto;padding:0 18px;}

  /* ---------- header ---------- */
  header{
    padding:34px 0 20px;
    border-bottom:1.5px solid var(--peri-line);
    margin-bottom:26px;
  }
  h1{
    font-family:'Fraunces',serif;
    font-weight:600;font-size:clamp(34px,9vw,48px);
    line-height:1;letter-spacing:-.015em;color:var(--ink);
  }
  .datebar{
    display:flex;justify-content:space-between;align-items:flex-end;
    gap:14px;margin-top:14px;flex-wrap:wrap;
  }
  .dateline{font-size:14px;color:var(--muted);}
  .dateline input{
    font-family:'Inter';font-size:14px;color:var(--ink);
    border:none;background:transparent;border-bottom:1.5px dotted var(--peri-line);
    padding:2px 4px;width:150px;
  }
  .dateline input:focus{outline:none;border-bottom-color:var(--peri);}
  .savednote{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--muted);letter-spacing:.04em;}

  /* ---------- section frame ---------- */
  section{margin-bottom:26px;}
  .label{
    display:flex;align-items:baseline;gap:9px;margin-bottom:11px;
  }
  .label h2{
    font-family:'Fraunces','Georgia',serif;font-weight:900;font-size:23px;
    letter-spacing:-.01em;color:#141418;
    text-rendering:optimizeLegibility;
  }
  .label .hint{font-size:12.5px;color:#565660;font-style:italic;}

  /* ---------- THE ONE THING (signature) ---------- */
  .onething{
    background:var(--oxblood);
    color:#fff;border-radius:14px;padding:20px 20px 18px;
    position:relative;overflow:hidden;
  }
  .onething::after{
    content:"01";font-family:'Fraunces',serif;font-weight:900;
    position:absolute;right:14px;top:2px;font-size:74px;
    color:rgba(255,255,255,.09);line-height:1;
  }
  .onething .label h2{color:#fff;}
  .onething .label .hint{color:rgba(255,255,255,.72);}
  .onething .who{
    font-family:'JetBrains Mono',monospace;font-size:10.5px;
    letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.6);
    margin-bottom:7px;
  }
  .onething input.big{
    width:100%;background:transparent;border:none;
    border-bottom:1.5px solid rgba(255,255,255,.32);
    color:#fff;font-family:'Fraunces',serif;font-size:20px;font-weight:500;
    padding:4px 0 8px;
  }
  .onething input.big::placeholder{color:rgba(255,255,255,.4);font-style:italic;font-weight:400;}
  .onething input.big:focus{outline:none;border-bottom-color:#fff;}
  .firststep{margin-top:15px;}
  .firststep .cue{
    font-size:12px;color:rgba(255,255,255,.72);margin-bottom:5px;
  }
  .firststep .cue b{color:#fff;font-weight:600;}
  .onething textarea{
    width:100%;background:rgba(255,255,255,.1);border:none;border-radius:8px;
    color:#fff;font-family:'Inter';font-size:14.5px;padding:10px 12px;resize:none;
    line-height:1.45;
  }
  .onething textarea::placeholder{color:rgba(255,255,255,.45);}
  .onething textarea:focus{outline:1.5px solid rgba(255,255,255,.5);}

  /* ---------- task tiers ---------- */
  .tier{margin-bottom:14px;}
  .tier-head{
    font-family:'JetBrains Mono',monospace;font-size:11px;
    letter-spacing:.14em;text-transform:uppercase;margin-bottom:2px;
    display:flex;align-items:center;gap:8px;
  }
  .tier-head .dot{width:8px;height:8px;border-radius:50%;flex:none;}
  .tier-head .sub{font-family:'Inter';text-transform:none;letter-spacing:0;
    font-size:12px;color:var(--muted);font-style:italic;}
  .t-ess .dot{background:var(--oxblood);}
  .t-sec .dot{background:var(--peri);}
  .t-nice .dot{background:var(--olive);}

  .taskrow{display:flex;align-items:center;gap:10px;padding:3px 0;}
  .taskrow .box{
    width:19px;height:19px;border:1.6px solid var(--peri-line);border-radius:5px;
    flex:none;cursor:pointer;transition:.15s;position:relative;background:var(--paper);
  }
  .taskrow .box.on{background:var(--peri);border-color:var(--peri);}
  .taskrow .box.on::after{
    content:"";position:absolute;left:5.5px;top:2px;width:5px;height:9px;
    border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg);
  }
  .t-ess .box.on{background:var(--oxblood);border-color:var(--oxblood);}
  .t-nice .box.on{background:var(--olive);border-color:var(--olive);}
  .taskrow input.task{
    flex:1;border:none;background:transparent;font-size:15px;color:var(--ink);
    padding:5px 2px;border-bottom:1px solid transparent;
  }
  .taskrow input.task:focus{outline:none;border-bottom-color:var(--peri-line);}
  .taskrow input.task.done{text-decoration:line-through;color:var(--muted);}

  /* ---------- time blocks ---------- */
  .tb-legend{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
  .chip{
    font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.08em;
    padding:4px 9px;border-radius:20px;cursor:pointer;text-transform:uppercase;
    border:1.5px solid transparent;user-select:none;transition:.12s;
  }
  .chip.sel{box-shadow:0 0 0 2px var(--ink) inset;}
  .c-mtg{background:var(--oxblood-soft);color:var(--cherry);}
  .c-deep{background:var(--peri-soft);color:var(--peri);}
  .c-admin{background:#EAEFE0;color:var(--olive);}
  .c-me{background:#F3ECDA;color:#8a6d2f;}
  .legend-lbl{font-size:11.5px;color:var(--muted);align-self:center;margin-right:2px;}

  .blocks{border:1.5px solid var(--peri-line);border-radius:12px;overflow:hidden;background:var(--paper);}
  .blk{display:flex;align-items:stretch;border-bottom:1px solid var(--peri-line);min-height:34px;}
  .blk.half{border-bottom:1px solid var(--peri-soft);min-height:30px;}
  .blk:last-child{border-bottom:none;}
  .blk .hr{
    font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);
    width:48px;flex:none;display:flex;align-items:center;justify-content:center;
    border-right:1px solid var(--peri-soft);background:#fcfcfa;
  }
  .blk.half .hr{background:#fdfdfc;}
  .blk .swatch{width:6px;flex:none;background:transparent;transition:.15s;cursor:pointer;}
  .blk.m-mtg .swatch{background:var(--oxblood);}
  .blk.m-deep .swatch{background:var(--peri);}
  .blk.m-admin .swatch{background:var(--olive);}
  .blk.m-me .swatch{background:#c9a34a;}
  .blk input{
    flex:1;border:none;background:transparent;font-size:14px;color:var(--ink);padding:6px 11px;
  }
  .blk input:focus{outline:none;}
  .blk.m-mtg input{background:rgba(110,31,42,.045);}
  .blk.m-deep input{background:rgba(108,108,176,.05);}
  .blk.m-admin input{background:rgba(107,112,67,.05);}
  .blk.m-me input{background:rgba(201,163,74,.06);}

  /* ---------- parking lot ---------- */
  .parking textarea{
    width:100%;min-height:170px;border:1.5px solid var(--peri-line);border-radius:12px;
    background:var(--paper);padding:13px 15px;font-family:'Inter';font-size:14.5px;
    color:var(--ink);resize:vertical;line-height:1.55;
  }
  .parking textarea:focus{outline:none;border-color:var(--peri);}
  .parking textarea::placeholder{color:#b3b3bd;}

  /* ---------- weed gate ---------- */
  .gate{
    background:var(--peri-soft);border-radius:12px;padding:16px 17px;
    display:flex;align-items:center;gap:14px;flex-wrap:wrap;
  }
  .gate .txt{flex:1;min-width:180px;}
  .gate .txt .g-title{font-family:'Fraunces','Georgia',serif;font-weight:900;font-size:17px;color:#141418;margin-bottom:2px;}
  .gate .txt .g-sub{font-size:12.5px;color:#565660;}
  .gate .toggle{
    display:flex;align-items:center;gap:9px;font-size:13px;color:var(--peri);
    font-weight:600;cursor:pointer;user-select:none;
  }
  .gate .sw{width:44px;height:25px;border-radius:20px;background:var(--peri-line);
    position:relative;transition:.18s;flex:none;}
  .gate .sw::after{content:"";position:absolute;top:2.5px;left:2.5px;width:20px;height:20px;
    border-radius:50%;background:#fff;transition:.18s;}
  .gate .toggle.on .sw{background:var(--olive);}
  .gate .toggle.on .sw::after{transform:translateX(19px);}

  /* ---------- footer ---------- */
  .foot{display:flex;justify-content:space-between;align-items:center;gap:12px;
    margin-top:32px;padding-top:18px;border-top:1.5px solid var(--peri-line);flex-wrap:wrap;}
  .btn{
    font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;
    text-transform:uppercase;padding:10px 16px;border-radius:8px;border:1.5px solid var(--peri-line);
    background:var(--paper);color:var(--ink);cursor:pointer;transition:.15s;
  }
  .btn:hover{border-color:var(--peri);color:var(--peri);}
  .btn.warn:hover{border-color:var(--oxblood);color:var(--oxblood);}
  .foot .note{font-size:12px;color:var(--muted);}

  @media (prefers-reduced-motion:reduce){*{transition:none!important;}}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <h1>today</h1>
    <div class="datebar">
      <div class="dateline">
        <span id="weekday">—</span> · <input id="datefield" type="text" placeholder="date / notes">
      </div>
      <div class="savednote" id="savedstamp">saved automatically</div>
    </div>
  </header>

  <!-- THE ONE THING -->
  <section>
    <div class="onething">
      <div class="label"><h2>lowest hanging fruit</h2></div>
      <div class="who">what / who's waiting</div>
      <input class="big" id="ot_who" type="text" placeholder="">
      <div class="firststep">
        <div class="cue">first step — keep it small</div>
        <textarea id="ot_step" rows="2" placeholder=""></textarea>
      </div>
    </div>
  </section>

  <!-- TASK TIERS -->
  <section>
    <div class="label"><h2>everything else</h2></div>

    <div class="tier t-ess">
      <div class="tier-head"><span class="dot"></span>essential <span class="sub">— top priority, today</span></div>
      <div id="ess"></div>
    </div>
    <div class="tier t-sec">
      <div class="tier-head"><span class="dot"></span>secondary <span class="sub">— bonus if done</span></div>
      <div id="sec"></div>
    </div>
    <div class="tier t-nice">
      <div class="tier-head"><span class="dot"></span>nice to finish <span class="sub">— if not, nbd</span></div>
      <div id="nice"></div>
    </div>
  </section>

  <!-- TIME BLOCKS -->
  <section>
    <div class="label"><h2>the day</h2><span class="hint">tap a color, then a row to paint it</span></div>
    <div class="tb-legend" id="legend">
      <span class="legend-lbl">paint:</span>
      <span class="chip c-mtg" data-m="mtg">meeting</span>
      <span class="chip c-deep" data-m="deep">deep work</span>
      <span class="chip c-admin" data-m="admin">admin</span>
      <span class="chip c-me" data-m="me">me / break</span>
      <span class="chip" data-m="" style="background:#eee;color:#888;">clear</span>
    </div>
    <div class="blocks" id="blocks"></div>
  </section>

  <!-- PARKING LOT -->
  <section class="parking">
    <div class="label"><h2>save for later</h2></div>
    <textarea id="parking" placeholder=""></textarea>
  </section>

  <!-- WEED GATE -->
  <section>
    <div class="gate">
      <div class="txt">
        <div class="g-title">the gate</div>
        <div class="g-sub">first smoke after the first step's done</div>
      </div>
      <div class="toggle" id="gate"><span class="sw"></span><span id="gatelabel">not yet</span></div>
    </div>
  </section>

  <div class="foot">
    <span class="note">everything saves as you type · comes back when you return</span>
    <button class="btn warn" id="reset">start fresh day</button>
  </div>

</div>

<script>
const $=s=>document.querySelector(s);
const STORE="ashley_planner_v1";
let state={date:"",ot_who:"",ot_step:"",parking:"",gate:false,
  ess:[],sec:[],nice:[],blocks:{}};

// weekday
const days=["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
$("#weekday").textContent=days[new Date().getDay()];

// ---- storage ----
async function load(){
  try{
    const r=await window.storage.get(STORE);
    if(r&&r.value) state=Object.assign(state,JSON.parse(r.value));
  }catch(e){/* first run, no key */}
  hydrate();
}
let saveTimer=null;
function save(){
  clearTimeout(saveTimer);
  $("#savedstamp").textContent="saving…";
  saveTimer=setTimeout(async()=>{
    try{ await window.storage.set(STORE,JSON.stringify(state));
      $("#savedstamp").textContent="saved ✓";
    }catch(e){ $("#savedstamp").textContent="couldn't save — copy anything important"; }
  },350);
}

// ---- task tiers ----
const TIERS={ess:6,sec:4,nice:4};
function ensureRows(){
  for(const k in TIERS){
    if(!Array.isArray(state[k])) state[k]=[];
    while(state[k].length<TIERS[k]) state[k].push({t:"",done:false});
  }
}
function renderTier(key){
  const c=$("#"+key); c.innerHTML="";
  state[key].forEach((row,i)=>{
    const d=document.createElement("div"); d.className="taskrow";
    const box=document.createElement("div"); box.className="box"+(row.done?" on":"");
    const inp=document.createElement("input"); inp.className="task"+(row.done?" done":"");
    inp.type="text"; inp.value=row.t; inp.placeholder="…";
    box.onclick=()=>{row.done=!row.done;box.classList.toggle("on");inp.classList.toggle("done");save();};
    inp.oninput=()=>{row.t=inp.value;save();};
    d.append(box,inp); c.append(d);
  });
}

// ---- time blocks ----
const HOURS=[];
(function(){
  const lbl=["7a","8a","9a","10a","11a","12p","1p","2p","3p","4p","5p","6p","7p"];
  lbl.forEach(h=>{ HOURS.push({key:h+":00",label:h,half:false});
                   HOURS.push({key:h+":30",label:"",half:true}); });
})();
let paintMode="deep";
function renderBlocks(){
  const c=$("#blocks"); c.innerHTML="";
  HOURS.forEach(H=>{
    const k=H.key;
    const b=document.createElement("div"); b.className="blk"+(H.half?" half":"");
    const bd=state.blocks[k]||{m:"",t:""};
    if(bd.m) b.classList.add("m-"+bd.m);
    const hr=document.createElement("div"); hr.className="hr"; hr.textContent=H.label;
    const sw=document.createElement("div"); sw.className="swatch";
    const inp=document.createElement("input"); inp.type="text"; inp.value=bd.t||"";
    const paint=()=>{ bd.m=paintMode; state.blocks[k]=bd;
      b.className="blk"+(H.half?" half":"")+(paintMode?(" m-"+paintMode):""); save(); };
    hr.onclick=paint; sw.onclick=paint;
    inp.oninput=()=>{bd.t=inp.value;state.blocks[k]=bd;save();};
    b.append(hr,sw,inp); c.append(b);
  });
}
$("#legend").querySelectorAll(".chip").forEach(ch=>{
  ch.onclick=()=>{
    paintMode=ch.dataset.m;
    $("#legend").querySelectorAll(".chip").forEach(x=>x.classList.remove("sel"));
    ch.classList.add("sel");
  };
});
$("#legend").querySelector('[data-m="deep"]').classList.add("sel");

// ---- gate ----
function renderGate(){
  const g=$("#gate");
  g.classList.toggle("on",state.gate);
  $("#gatelabel").textContent=state.gate?"open":"not yet";
}
$("#gate").onclick=()=>{state.gate=!state.gate;renderGate();save();};

// ---- simple fields ----
["ot_who","ot_step","parking","datefield"].forEach(id=>{});
function bindField(id,key){
  const el=$("#"+id); el.value=state[key]||"";
  el.oninput=()=>{state[key]=el.value;save();};
}

// ---- hydrate ----
function hydrate(){
  ensureRows();
  $("#datefield").value=state.date||"";
  $("#datefield").oninput=e=>{state.date=e.target.value;save();};
  bindField("ot_who","ot_who");
  bindField("ot_step","ot_step");
  bindField("parking","parking");
  renderTier("ess");renderTier("sec");renderTier("nice");
  renderBlocks();renderGate();
}

// ---- reset ----
$("#reset").onclick=()=>{
  if(!confirm("Clear everything and start a fresh day? This can't be undone.")) return;
  state={date:"",ot_who:"",ot_step:"",parking:"",gate:false,ess:[],sec:[],nice:[],blocks:{}};
  ensureRows(); hydrate(); save();
};

load();
</script>
</body>
</html>